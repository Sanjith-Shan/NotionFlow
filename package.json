{
  "name": "notionflow",
  "version": "0.1.0",
  "description": "AI knowledge agent for Notion workspaces. RAG search, auto-tagging, and weekly digests, exposed as Notion Worker agent tools, a CLI, and a React dashboard.",
  "type": "module",
  "license": "MIT",
  "author": "Sanjith Shanmugavel",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "notionflow": "bin/notionflow.mjs"
  },
  "scripts": {
    "cli": "tsx src/cli/index.ts",
    "index": "tsx scripts/index-workspace.ts",
    "serve": "tsx server/index.ts",
    "demo": "tsx scripts/demo.ts",
    "eval": "tsx eval/run-eval.ts",
    "build:worker-corpus": "tsx scripts/build-worker-corpus.ts",
    "dev:web": "vite",
    "build:web": "vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p worker/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@notionhq/client": "^5.22.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "open": "^10.1.0",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
