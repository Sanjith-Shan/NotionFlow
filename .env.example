# Notion integration token. Create one at notion.so/my-integrations and share
# the pages you want indexed with the integration. Required for live workspace use.
NOTION_API_TOKEN=

# OpenAI key. Used for embeddings (text-embedding-3-small) and for answer
# generation (gpt-4o-mini). Optional. Without it NotionFlow falls back to a
# local TF-IDF retriever and extractive answers, so the demo runs with no keys.
OPENAI_API_KEY=

# Anthropic key. Optional. When LLM_PROVIDER is set to anthropic, answers are
# generated with Claude (claude-sonnet-4-6).
ANTHROPIC_API_KEY=

# Which provider generates answers. One of openai, anthropic, or none.
# Defaults to openai when OPENAI_API_KEY is present, otherwise none.
LLM_PROVIDER=

# Where the vector index is read from and written to.
INDEX_PATH=data/index.json

# Web dashboard port.
PORT=3000
